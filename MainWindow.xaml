<Window x:Class="Chapter_Splitter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Chapter_Splitter" 
        xmlns:comps="clr-namespace:Chapter_Splitter.Components" 
        mc:Ignorable="d" SnapsToDevicePixels="True" ResizeMode="NoResize"
        Title="MKV Chapter Splitter" Width="637" Height="641">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Menu Grid.Row="0" Margin="0,0,0,0">
            <MenuItem Header="_Settings">
                <MenuItem Header="Select FFmpeg bin path." Click="FolderBrowse_FFmpeg"/>
                <MenuItem Header="Clear saved paths." Click="Click_ClearSettings"/>
            </MenuItem>
        </Menu>
        <comps:MissingDependency x:Name="MissingDependencyControl" 
                                 Panel.ZIndex="1" Grid.Row="1" Grid.RowSpan="3" 
                                 Visibility="Hidden"/>
        <GroupBox Grid.Row="1" Header="Video Input" Margin="10,5,10,0" Height="120">
            <Grid>
                <comps:FileDrop x:Name="FileDropControl" />
                <comps:VideoInfo x:Name="VideoInfoControl" Visibility="Hidden"/>
            </Grid>
        </GroupBox>
        <comps:EpisodeEditor x:Name="EpisodeEditorControl" Grid.Row="2" Margin="10,0,10,0" Visibility="Visible"/>
    </Grid>
</Window>
